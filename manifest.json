{
  "manifest_version": 3,
  "name": "Мой Умный Переключатель",
  "version": "1.0",
  "description": "Пример расширения с переключателем on/off",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_title": "Мой Умный Переключатель",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}